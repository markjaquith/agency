{
  "version": 2,
  "repositories": {
    "agency": {
      "remote": "https://github.com/markjaquith/agency.git"
    },
    "effect": {
      "remote": "https://github.com/Effect-TS/effect.git"
    }
  },
  "worktreeCreateCommand": [
    "wt",
    "-C",
    "{repo}",
    "-y",
    "--config-set",
    "worktree-path=\"{worktree}\"",
    "switch",
    "--create",
    "--base",
    "{base}",
    "{branch}",
    "--no-cd",
    "--format",
    "json"
  ]
}
